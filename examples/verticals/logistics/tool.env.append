# Optional — only if you prefer .env over `python main.py --example logistics`.
# Replace REPO_ROOT with the absolute path to this monorepo.

# AGENTIC_ORCHESTRATOR_CONTEXT_FILE=REPO_ROOT/examples/verticals/logistics/orchestrator-context.md
# AGENTIC_EXTRA_AGENT_PROVIDERS_CATALOG_DIRS=REPO_ROOT/examples/verticals/logistics/agent_providers
# AGENTIC_EXTRA_MCP_PROVIDERS_PATH=REPO_ROOT/examples/verticals/logistics/mcp_providers
#
# Simulated fixtures MCP (requires: pip install mcp in the tool venv):
# AGENTIC_MCP_LOGISTICS_SIM_ENABLED=1
# AGENTIC_LOGISTICS_SIM_MCP_PY is set automatically when using --example logistics.
#
# Optional real ERP/WMS MCP over streamable HTTP (you host the MCP server / bridge):
# AGENTIC_MCP_LOGISTICS_ERP_HTTP_ENABLED=1
# LOGISTICS_ERP_MCP_URL=https://your-mcp-host/your-erp-mcp
# AGENTIC_MCP_LOGISTICS_WMS_HTTP_ENABLED=1
# LOGISTICS_WMS_MCP_URL=https://your-mcp-host/your-wms-mcp
