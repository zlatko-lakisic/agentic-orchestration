# Copy to .env and adjust. Loaded automatically on npm start.

# Listen on all interfaces (LAN / Docker). Default in code is 127.0.0.1 only.
AGENTIC_WEB_HOST=0.0.0.0

# AGENTIC_WEB_PORT=3847
# AGENTIC_TOOL_ROOT=../agentic-orchestration-tool
# AGENTIC_PYTHON=

# When stopping the background web server: ./stop-web-bg.sh with this set to 1 runs fuser -k on AGENTIC_WEB_PORT (Linux).
# AGENTIC_WEB_KILL_PORT=1

# Optional: pass through vertical overlay env vars to Python (same names as agentic-orchestration-tool/.env).
# See ../agentic-orchestration-tool/examples/verticals/healthcare/web.env.append
# AGENTIC_ORCHESTRATOR_CONTEXT_FILE=
# AGENTIC_EXTRA_AGENT_PROVIDERS_CATALOG_DIRS=
# AGENTIC_EXTRA_MCP_PROVIDERS_PATH=
# AGENTIC_MCP_HEALTHCARE_TOOLS_ENABLED=1
