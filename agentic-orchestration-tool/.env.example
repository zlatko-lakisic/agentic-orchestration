# Repo layout: workflow YAML → config/workflows/*.yaml; --dynamic provider defs → config/providers/*.yaml
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o-mini

# Anthropic Claude (providers with type: anthropic in config/providers/*.yaml)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional custom API base (proxy / region endpoint). Also accepted: ANTHROPIC_API_URL.
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: OpenAI-compatible local server (LM Studio, vLLM, Ollama /v1, etc.).
# If unset, cloud OpenAI is used. `/v1` is appended when missing.
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1

# Dynamic orchestration (--dynamic): planner model and limits (uses OPENAI_API_KEY / OPENAI_BASE_URL).
# AGENTIC_PLANNER_MODEL=gpt-4o-mini
# AGENTIC_PLANNER_MAX_STEPS=8
# Set to 0/false if your server does not support response_format json_object.
# AGENTIC_PLANNER_JSON_MODE=1
#
# Dynamic runs always persist planner + crew excerpt JSON under __orchestrator_sessions__/
# (gitignored). With no --orchestrator-session and no AGENTIC_ORCHESTRATOR_SESSION, the file is
# `<slug>.json` where slug defaults to "default" (override slug via AGENTIC_ORCHESTRATOR_DEFAULT_SESSION).
# AGENTIC_ORCHESTRATOR_DEFAULT_SESSION=my-project
# Same as CLI --orchestrator-session NAME when set:
# AGENTIC_ORCHESTRATOR_SESSION=my-project
# Cap stored planner user/assistant pairs (default 12). Crew output excerpt length default 15000.
# AGENTIC_ORCHESTRATOR_MAX_PLANNER_TURNS=12
# AGENTIC_ORCHESTRATOR_EXCERPT_CHARS=15000

# Ollama URL (used by workflow router and Ollama providers)
OLLAMA_HOST=http://127.0.0.1:11434
# Non-quiet runs set AGENTIC_OLLAMA_VERBOSE so `ollama pull` streams progress (TTY: in-place \r per
# layer; piped: one final line per `pulling <digest>:` key). Embedded `ollama serve`
# stays silent; set AGENTIC_OLLAMA_SERVE_DEBUG=INFO only if you need serve logs.
#
# Dynamic planner: optional min_vram_gb per provider YAML, plus Ollama model heuristics when unset.
# nvidia-smi picks largest GPU; set AGENTIC_ASSUME_VRAM_GB=8 to override detection.
# AGENTIC_DISABLE_HARDWARE_FILTER=1  # never drop catalog entries by VRAM
# AGENTIC_VRAM_HEURISTICS=0         # only use explicit min_vram_gb from YAML
# AGENTIC_HARDWARE_FILTER_QUIET=1    # no stderr line about excluded providers
# Model id for routing when you pass a TASK on the CLI (must be pulled in Ollama)
ROUTER_OLLAMA_MODEL=llama3.2

# Optional: directories (os.pathsep-separated) scanned for extra Provider classes.
# Windows example: AGENTIC_EXTRA_PROVIDERS_PATH=D:\my-providers;D:\shared-providers
# Unix example:   AGENTIC_EXTRA_PROVIDERS_PATH=/home/me/my-providers:/opt/providers
# AGENTIC_EXTRA_PROVIDERS_PATH=

# After saving extracted files, run npm install/test/build under the output tree (default on).
# Set to 0, false, no, or off to skip (same effect as CLI --no-verify).
# AGENTIC_VERIFY=1

