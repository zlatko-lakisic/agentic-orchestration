# Repo layout: workflow YAML → config/workflows/*.yaml; --dynamic defs → config/agent_providers/*.yaml
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o-mini

# Anthropic Claude (type: anthropic in config/agent_providers/*.yaml)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional custom API base (proxy / region endpoint). Also accepted: ANTHROPIC_API_URL.
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Hugging Face Hub (type: huggingface — LiteLLM). Prefer HF_TOKEN.
# HF_TOKEN=hf_your_token_here
# Alternative name also supported by the tooling:
# HUGGINGFACE_API_KEY=hf_your_token_here
# Optional Inference Endpoint / custom API base:
# HUGGINGFACE_API_BASE=https://your-endpoint.huggingface.cloud

# Optional: OpenAI-compatible local server (LM Studio, vLLM, Ollama /v1, etc.).
# If unset, cloud OpenAI is used. `/v1` is appended when missing.
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1

# Dynamic orchestration (--dynamic): planner model and limits.
# The planner runs via LiteLLM by default (same backbone CrewAI uses), so you can point it at:
# - OpenAI:      openai/gpt-4o-mini
# - Anthropic:   anthropic/claude-3-5-sonnet-20241022
# - HuggingFace: huggingface/meta-llama/Llama-3.3-70B-Instruct
# - Ollama:      ollama/llama3.2
# If you omit the "<provider>/" prefix, "openai/" is assumed.
# AGENTIC_PLANNER_MODEL=openai/gpt-4o-mini
# AGENTIC_PLANNER_MAX_STEPS=8
# Set to 0/false if your server does not support response_format json_object.
# AGENTIC_PLANNER_JSON_MODE=1
# Set to 0 to force the legacy direct OpenAI HTTP call (requires OPENAI_API_KEY).
# AGENTIC_PLANNER_USE_LITELLM=1
# If the planner returns invalid JSON (e.g., empty steps), retry once with a repair instruction.
# AGENTIC_PLANNER_REPAIR_RETRY=1
# OpenAI 429 handling:
# - Retry/backoff count for transient 429s
# AGENTIC_PLANNER_429_RETRIES=2
# - If 429 includes "Request too large ... TPM", the tool auto-shrinks the planner context and retries:
#   keep only the last N non-system messages and truncate long ones.
# AGENTIC_PLANNER_CONTEXT_TURNS=6
# AGENTIC_PLANNER_MESSAGE_CHARS=8000
#
# Dynamic runs always persist planner + crew excerpt JSON under __orchestrator_sessions__/
# (gitignored). With no --orchestrator-session and no AGENTIC_ORCHESTRATOR_SESSION, the file is
# `<slug>.json` where slug defaults to "default" (override slug via AGENTIC_ORCHESTRATOR_DEFAULT_SESSION).
# AGENTIC_ORCHESTRATOR_DEFAULT_SESSION=my-project
# Same as CLI --orchestrator-session NAME when set:
# AGENTIC_ORCHESTRATOR_SESSION=my-project
# Cap stored planner user/assistant pairs (default 12). Crew output excerpt length default 15000.
# Each assistant turn includes the planner JSON plus a snapshot of resolved agent providers/tasks.
# AGENTIC_ORCHESTRATOR_MAX_PLANNER_TURNS=12
# AGENTIC_ORCHESTRATOR_EXCERPT_CHARS=15000
# AGENTIC_ORCHESTRATOR_TASK_DESC_CHARS=500
# AGENTIC_ORCHESTRATOR_TASK_OUTPUT_CHARS=320

# Vertical / industry overlays (optional)
# Append free-text domain rules to the dynamic planner, iterative controller, learning evaluator,
# and faithfulness QA system prompts (e.g. healthcare compliance tone, no patient-specific advice).
# AGENTIC_ORCHESTRATOR_CONTEXT=You are assisting US healthcare operations and medtech strategy teams...
# Or point at a markdown/text file (UTF-8). When both are set, the file is used if it can be read.
# AGENTIC_ORCHESTRATOR_CONTEXT_FILE=/absolute/path/to/orchestrator-context.md
#
# Merge extra agent-provider YAML directories into the dynamic planner catalog (same layout as
# config/agent_providers/). Use distinct provider ids in overlays. Path list uses os.pathsep.
# AGENTIC_EXTRA_AGENT_PROVIDERS_CATALOG_DIRS=/abs/path/to/repo/examples/verticals/healthcare/agent_providers
#
# MCP catalog already supports AGENTIC_EXTRA_MCP_PROVIDERS_PATH (see below); add a healthcare MCP dir the same way.
# AGENTIC_EXTRA_MCP_PROVIDERS_PATH=/abs/path/to/repo/examples/verticals/healthcare/mcp_providers

# Ollama URL (used by workflow router and Ollama providers)
OLLAMA_HOST=http://127.0.0.1:11434
# Non-quiet runs set AGENTIC_OLLAMA_VERBOSE so `ollama pull` streams progress (TTY: in-place \r per
# layer; piped: one final line per `pulling <digest>:` key). Embedded `ollama serve`
# stays silent; set AGENTIC_OLLAMA_SERVE_DEBUG=INFO only if you need serve logs.
# When verbose is off, `ollama pull` still streams normalized `(progress) ollama pull: ...` lines on
# stderr for the web UI pinned bar. Set AGENTIC_OLLAMA_PULL_PROGRESS_STDERR=0 to suppress them.
#
# CrewAI native MCP: mask MCPToolResolver tools_list UnboundLocalError (empty discovery) instead of crashing.
# AGENTIC_CREWAI_MCP_TOOLS_LIST_HOTFIX=0
#
# Dynamic planner hardware filtering:
# - Optional per-provider `hardware.architecture` in catalog YAML (cpu/gpu/tpu).
# - Optional per-provider min_vram_gb, plus Ollama model heuristics when unset.
# nvidia-smi picks largest GPU; set AGENTIC_ASSUME_VRAM_GB=8 to override detection.
# AGENTIC_AVAILABLE_ARCHITECTURES=cpu,gpu  # manual override (comma-separated)
# AGENTIC_ASSUME_GPU=1                      # force GPU as available
# AGENTIC_ASSUME_TPU=1                      # force TPU as available
# If borderline models are too slow, cap the effective VRAM used by the filter:
# - Treat your GPU as only 70% of its VRAM:
#   AGENTIC_MAX_VRAM_FRACTION=0.7
# - Or cap to an absolute value in GiB:
#   AGENTIC_MAX_VRAM_GB=5.6
# AGENTIC_DISABLE_HARDWARE_FILTER=1  # never drop catalog entries by VRAM
# AGENTIC_VRAM_HEURISTICS=0         # only use explicit min_vram_gb from YAML
# AGENTIC_HARDWARE_FILTER_QUIET=1    # no stderr line about excluded agent providers
# Credential filter (dynamic/static catalog): summarize skips into one stderr line when many (default >= 8).
# AGENTIC_CREDENTIAL_SKIP_SUMMARY_AT=8
# AGENTIC_CREDENTIAL_SKIP_VERBOSE=1  # always print one line per skipped provider
# Dynamic: disable heuristic MCP selection from user goal text (default on when catalog is non-empty).
# AGENTIC_DISABLE_MCP_GOAL_MATCH=1
# Agents with MCP tools: skip appended backstory hint about flat tool arguments (not recommended).
# AGENTIC_DISABLE_MCP_TOOL_HINT=1
# Step-to-step continuity: inject previous step output into the next task description.
# Disable if you prefer strict separation or you hit context-length issues.
# AGENTIC_STEP_CONTEXT_INJECT=1
# AGENTIC_STEP_CONTEXT_CHARS=4000
# Non-verbose run progress lines (Web UI can surface these in the activity bar)
# Set to 0/false to disable.
# AGENTIC_PROGRESS=1
# Dynamic-iterative: stream each intermediate crew answer to stdout (default off). When off,
# only the final synthesis is printed to stdout (or the last round if --dynamic-iterative-no-synthesize).
# AGENTIC_DYNAMIC_ITER_STREAM_STEPS=1

# Local learning loop (no model training; uses evaluation + user votes + stored stats)
# Writes under __orchestrator_learning__/ (gitignored):
# - stats.json (aggregates)
# - traces.jsonl (decision traces)
# - pending_ratings.jsonl (web UI votes, consumed on next planner run)
# AGENTIC_LEARNING=1
# AGENTIC_LEARNING_EVAL=1
# AGENTIC_EVAL_MODEL=  # defaults to controller/planner model
# AGENTIC_EVAL_GOAL_CHARS=2000
# AGENTIC_EVAL_OUTPUT_CHARS=12000

# Final answer QA (hallucinations / unverified claims): extra LLM pass after --dynamic or after
# --dynamic-iterative synthesis; report is printed to stderr (visible in the web UI activity log).
# AGENTIC_FINAL_QA=1
# AGENTIC_QA_MODEL=  # defaults: AGENTIC_EVAL_MODEL -> AGENTIC_ITERATIVE_CONTROLLER_MODEL -> AGENTIC_PLANNER_MODEL
# AGENTIC_QA_GOAL_CHARS=2000
# AGENTIC_QA_OUTPUT_CHARS=16000

# Answer cache (dynamic / dynamic-iterative)
# If the same goal is asked again within the same orchestrator session, return the last finalized
# answer immediately and ask for confirmation ("Reply `no` to re-run.").
# AGENTIC_ANSWER_CACHE=1

# Local knowledge base (aggregates outputs across runs)
# Stores finalized outputs into __orchestrator_kb__/kb.sqlite3 (gitignored) and retrieves relevant
# snippets to include in the planner prompt.
# AGENTIC_KB=1
# AGENTIC_KB_MAX_HITS=4
# AGENTIC_KB_SNIPPET_CHARS=600
# AGENTIC_KB_DOC_CHARS=20000
# Iterative dynamic controller (when you run --dynamic-iterative --dynamic-iterative-auto)
# AGENTIC_ITERATIVE_CONTROLLER_MODEL=gpt-4o-mini
# AGENTIC_ITERATIVE_CONTROLLER_EXCERPT_CHARS=12000
# The controller will also attempt to estimate remaining rounds; it improves as more rounds complete.
# Model id for routing when you pass a TASK on the CLI (must be pulled in Ollama)
ROUTER_OLLAMA_MODEL=llama3.2

# TPU-serving OpenAI-compatible endpoints for provider types:
# - type: vllm      -> VLLM_BASE_URL (or YAML vllm_base_url/base_url)
# - type: jetstream -> JETSTREAM_BASE_URL (or YAML jetstream_base_url/base_url)
# VLLM_BASE_URL=http://127.0.0.1:8000
# VLLM_API_KEY=
# JETSTREAM_BASE_URL=http://127.0.0.1:8001
# JETSTREAM_API_KEY=

# Optional: directories (os.pathsep-separated) scanned for extra AgentProvider classes.
# Prefer AGENTIC_EXTRA_AGENT_PROVIDERS_PATH; AGENTIC_EXTRA_PROVIDERS_PATH is still read if unset.
# Windows example: AGENTIC_EXTRA_AGENT_PROVIDERS_PATH=D:\my-agent-providers
# Unix example:   AGENTIC_EXTRA_AGENT_PROVIDERS_PATH=/home/me/my-agent-providers
# AGENTIC_EXTRA_AGENT_PROVIDERS_PATH=

# Home Assistant MCP catalog entry: config/mcp_providers/home_assistant.yaml
# https://www.home-assistant.io/integrations/mcp_server/ — base URL without trailing slash;
# create a long-lived access token under Profile → Security.
# HOME_ASSISTANT_URL=https://your-instance.example.com
# HOME_ASSISTANT_TOKEN=

# Optional: web search MCP servers (entries are automatically hidden unless required env vars are set).
# These are templates: you must run/host an MCP server and point the *_MCP_URL at it.
# TAVILY_API_KEY=
# TAVILY_MCP_URL=https://your-tavily-mcp.example.com/mcp
# BRAVE_SEARCH_API_KEY=
# BRAVE_SEARCH_MCP_URL=https://your-brave-search-mcp.example.com/mcp

# Exa search MCP (config/mcp_providers/search_exa.yaml) — https://dashboard.exa.ai/api-keys
# EXA_API_KEY=

# Official URL fetch MCP (config/mcp_providers/fetch_url.yaml): pip install mcp-server-fetch into this venv, then:
# AGENTIC_MCP_FETCH_ENABLED=1

# Official MCP in-memory knowledge graph (config/mcp_providers/memory_knowledge_graph.yaml): requires Node/npx; opt-in:
# AGENTIC_MCP_MEMORY_MCP_ENABLED=1

# Official MCP filesystem server (config/mcp_providers/filesystem_local.yaml): absolute directory the model may access:
# FILESYSTEM_MCP_ALLOWED_DIRECTORY=D:\Projects\my-safe-root

# Optional: extra MCP provider YAML directories (os.pathsep-separated), merged with --mcp-providers-catalog.
# Windows example: AGENTIC_EXTRA_MCP_PROVIDERS_PATH=D:\my-mcp-providers
# AGENTIC_EXTRA_MCP_PROVIDERS_PATH=

# After saving extracted files, run npm install/test/build under the output tree (default on).
# Set to 0, false, no, or off to skip (same effect as CLI --no-verify).
# AGENTIC_VERIFY=1

