OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o-mini

# Optional: directories (os.pathsep-separated) scanned for extra Provider classes.
# Windows example: AGENTIC_EXTRA_PROVIDERS_PATH=D:\my-providers;D:\shared-providers
# Unix example:   AGENTIC_EXTRA_PROVIDERS_PATH=/home/me/my-providers:/opt/providers
# AGENTIC_EXTRA_PROVIDERS_PATH=
