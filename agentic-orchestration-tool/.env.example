# Repo layout: workflow YAML → config/workflows/*.yaml; --dynamic defs → config/agent_providers/*.yaml
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o-mini

# Anthropic Claude (type: anthropic in config/agent_providers/*.yaml)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional custom API base (proxy / region endpoint). Also accepted: ANTHROPIC_API_URL.
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Hugging Face Hub (type: huggingface — LiteLLM). Prefer HF_TOKEN.
# HF_TOKEN=hf_your_token_here
# Alternative name also supported by the tooling:
# HUGGINGFACE_API_KEY=hf_your_token_here
# Optional Inference Endpoint / custom API base:
# HUGGINGFACE_API_BASE=https://your-endpoint.huggingface.cloud

# Optional: OpenAI-compatible local server (LM Studio, vLLM, Ollama /v1, etc.).
# If unset, cloud OpenAI is used. `/v1` is appended when missing.
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1

# Dynamic orchestration (--dynamic): planner model and limits (uses OPENAI_API_KEY / OPENAI_BASE_URL).
# AGENTIC_PLANNER_MODEL=gpt-4o-mini
# AGENTIC_PLANNER_MAX_STEPS=8
# Set to 0/false if your server does not support response_format json_object.
# AGENTIC_PLANNER_JSON_MODE=1
#
# Dynamic runs always persist planner + crew excerpt JSON under __orchestrator_sessions__/
# (gitignored). With no --orchestrator-session and no AGENTIC_ORCHESTRATOR_SESSION, the file is
# `<slug>.json` where slug defaults to "default" (override slug via AGENTIC_ORCHESTRATOR_DEFAULT_SESSION).
# AGENTIC_ORCHESTRATOR_DEFAULT_SESSION=my-project
# Same as CLI --orchestrator-session NAME when set:
# AGENTIC_ORCHESTRATOR_SESSION=my-project
# Cap stored planner user/assistant pairs (default 12). Crew output excerpt length default 15000.
# Each assistant turn includes the planner JSON plus a snapshot of resolved agent providers/tasks.
# AGENTIC_ORCHESTRATOR_MAX_PLANNER_TURNS=12
# AGENTIC_ORCHESTRATOR_EXCERPT_CHARS=15000
# AGENTIC_ORCHESTRATOR_TASK_DESC_CHARS=500
# AGENTIC_ORCHESTRATOR_TASK_OUTPUT_CHARS=320

# Ollama URL (used by workflow router and Ollama providers)
OLLAMA_HOST=http://127.0.0.1:11434
# Non-quiet runs set AGENTIC_OLLAMA_VERBOSE so `ollama pull` streams progress (TTY: in-place \r per
# layer; piped: one final line per `pulling <digest>:` key). Embedded `ollama serve`
# stays silent; set AGENTIC_OLLAMA_SERVE_DEBUG=INFO only if you need serve logs.
#
# Dynamic planner: optional min_vram_gb per agent-provider YAML, plus Ollama model heuristics when unset.
# nvidia-smi picks largest GPU; set AGENTIC_ASSUME_VRAM_GB=8 to override detection.
# AGENTIC_DISABLE_HARDWARE_FILTER=1  # never drop catalog entries by VRAM
# AGENTIC_VRAM_HEURISTICS=0         # only use explicit min_vram_gb from YAML
# AGENTIC_HARDWARE_FILTER_QUIET=1    # no stderr line about excluded agent providers
# Credential filter (dynamic/static catalog): summarize skips into one stderr line when many (default >= 8).
# AGENTIC_CREDENTIAL_SKIP_SUMMARY_AT=8
# AGENTIC_CREDENTIAL_SKIP_VERBOSE=1  # always print one line per skipped provider
# Model id for routing when you pass a TASK on the CLI (must be pulled in Ollama)
ROUTER_OLLAMA_MODEL=llama3.2

# Optional: directories (os.pathsep-separated) scanned for extra AgentProvider classes.
# Prefer AGENTIC_EXTRA_AGENT_PROVIDERS_PATH; AGENTIC_EXTRA_PROVIDERS_PATH is still read if unset.
# Windows example: AGENTIC_EXTRA_AGENT_PROVIDERS_PATH=D:\my-agent-providers
# Unix example:   AGENTIC_EXTRA_AGENT_PROVIDERS_PATH=/home/me/my-agent-providers
# AGENTIC_EXTRA_AGENT_PROVIDERS_PATH=

# Home Assistant MCP catalog entry: config/mcp_providers/home_assistant.yaml
# https://www.home-assistant.io/integrations/mcp_server/ — base URL without trailing slash;
# create a long-lived access token under Profile → Security.
# HOME_ASSISTANT_URL=https://your-instance.example.com
# HOME_ASSISTANT_TOKEN=

# Optional: extra MCP provider YAML directories (os.pathsep-separated), merged with --mcp-providers-catalog.
# Windows example: AGENTIC_EXTRA_MCP_PROVIDERS_PATH=D:\my-mcp-providers
# AGENTIC_EXTRA_MCP_PROVIDERS_PATH=

# After saving extracted files, run npm install/test/build under the output tree (default on).
# Set to 0, false, no, or off to skip (same effect as CLI --no-verify).
# AGENTIC_VERIFY=1

