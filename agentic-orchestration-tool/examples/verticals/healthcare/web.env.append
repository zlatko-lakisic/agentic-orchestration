# Append these lines to agentic-orchestration-web/.env so the Web UI spawn inherits the same overlay.
# Replace REPO_ROOT with the absolute path to this monorepo. Use the same path style as your OS (Windows: D:\...).

AGENTIC_ORCHESTRATOR_CONTEXT_FILE=REPO_ROOT/agentic-orchestration-tool/examples/verticals/healthcare/orchestrator-context.md
AGENTIC_EXTRA_AGENT_PROVIDERS_CATALOG_DIRS=REPO_ROOT/agentic-orchestration-tool/examples/verticals/healthcare/agent_providers
AGENTIC_EXTRA_MCP_PROVIDERS_PATH=REPO_ROOT/agentic-orchestration-tool/examples/verticals/healthcare/mcp_providers
AGENTIC_MCP_HEALTHCARE_TOOLS_ENABLED=1
